{
  "VaultKeys": {
    "VaultUri": "http://127.0.0.1:8200",
    "SecretPath": "app1/config",
    "MountPoint": "secrets"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
